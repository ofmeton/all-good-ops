{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/daily-publish",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "app/api/cron/daily-publish/route.ts": {
      "maxDuration": 60
    },
    "app/api/approval-hook/route.ts": {
      "maxDuration": 30
    },
    "app/api/line-webhook/route.ts": {
      "maxDuration": 10
    }
  }
}
