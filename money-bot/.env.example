# ===========================================================================
# money-bot .env example  (spec: docs/superpowers/specs/2026-05-22-money-bot-design.md)
# ---------------------------------------------------------------------------
# 使い方:
#   1. このファイルを `.env.local` (or `.env`) にコピー
#   2. 各値を埋める (README.md の Phase 1 セットアップ手順を参照)
#   3. 値はチャットに貼らず、各プロバイダの UI / configure ウィザードに直接入力すること
#   4. Vercel デプロイ時は `vercel env add <KEY> production` でクラウド側にも投入
# ===========================================================================

# ---------------------------------------------------------------------------
# 1. Claude / Anthropic
# ---------------------------------------------------------------------------
# Vercel AI Gateway 経由を default 想定 (spec §6.1)。
# Gateway 経由ならプロバイダ markup 込みで観測しやすい。
# 直叩きに切り替えたい時のみ ANTHROPIC_API_KEY を使う。
ANTHROPIC_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=

# Agent SDK が読み込む既存 .claude/agents/ .claude/skills/ のルート (worktree root)
# 値: 絶対パス or リポルートからの相対パス。Vercel deploy 時は build に含めて bundle する想定。
# TODO(Phase 1): Vercel build から `.claude/` を参照できるよう vercel.json の includeFiles か bundleConfig を検討
CLAUDE_PROJECT_ROOT=

# ---------------------------------------------------------------------------
# 2. Supabase
# ---------------------------------------------------------------------------
# Project URL & keys (Supabase dashboard > Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# server-only。ブラウザに絶対露出させないこと
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# 3. LINE Messaging API (承認通知 / エラー通知)
# ---------------------------------------------------------------------------
# LINE Developers > Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# 承認通知の宛先 (個人アカウントの userId)。LINE_CHANNEL とは別。
# 取得方法: bot を友だち追加 → /api/line-webhook で受信した event.source.userId を控える
LINE_TO_USER_ID=

# LIFF (LINE Front-end Framework) — 承認 UI を LINE トーク内で開く場合のみ
# 軽量 Web 承認 UI を選んだ場合は空でよい
LIFF_ID=

# ---------------------------------------------------------------------------
# 4. Instagram (Meta Graph API)
# ---------------------------------------------------------------------------
# Facebook Business Manager > 連携した Instagram プロアカウントの長期トークン
# 60日有効。Phase 1 で refresh 自動化スクリプトを別途用意する想定 (TODO)
INSTAGRAM_GRAPH_API_TOKEN=
# Instagram ビジネスアカウント ID (Graph API で取得した数値 ID)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# 5. OpenAI (gpt-image-2 図解生成 — spec §6.1 / §7)
# ---------------------------------------------------------------------------
# 直叩きルート。Codex MCP 経由にする場合は不要 (要 Phase 1 判断)
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# 6. Vercel cron 用 secret
# ---------------------------------------------------------------------------
# cron endpoint を外部から叩かれないよう、Authorization ヘッダで検証する
# vercel.json の crons[].path に対する保護
CRON_SECRET=

# ---------------------------------------------------------------------------
# 7. Resend / Gmail (LINE 障害時のフォールバック通知 — spec §6.1)
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# 8. Kill switch / budget guard (spec §7)
# ---------------------------------------------------------------------------
# 月予算上限 (円)。Workflow 起動時に当月コスト累計と比較し超過なら即停止。
MONEY_BOT_MONTHLY_BUDGET_JPY=10000
# 緊急停止フラグ。1 を立てると次サイクルから workflow が冒頭で return する
MONEY_BOT_KILL_SWITCH=0

# ---------------------------------------------------------------------------
# 9. ai-radar 連携 (spec §6.4)
# ---------------------------------------------------------------------------
# 接続方式 α (direct Supabase read) の場合
AI_RADAR_SUPABASE_URL=
AI_RADAR_SUPABASE_ANON_KEY=
# 接続方式 β (公開 API endpoint) の場合
AI_RADAR_API_ENDPOINT=
AI_RADAR_API_KEY=
