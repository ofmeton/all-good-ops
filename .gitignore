# Secrets
secrets/
*.env
.env.*

# OS
.DS_Store
Thumbs.db

# Claude Code local
.claude/settings.local.json
.claude/worktrees/
.claire/

# Obsidian volatile state (UI レイアウト。共有設定 app/appearance/core-plugins/graph は追跡)
wiki/.obsidian/workspace.json

# Logs (keep structure, ignore content)
logs/*.log

# Temporary
*.tmp
*.bak

# Root-level scratch images (作業中スクショ。保管は outputs/screenshots/ 配下へ)
/*.png
/*.jpg
/*.jpeg

# Tool generated
.playwright-mcp/
*.egg-info/
__pycache__/
*.pyc

# Build / dependency artifacts (どのサブプロジェクトでも除外)
node_modules/
.next/
.turbo/
.vercel/
dist/
build/

# Per-project scratch directories (作業中の一時ファイル)
outputs/**/tmp/
outputs/**/_local-check/
outputs/**/_check/

# 再生成可能な生成物（ローカル保管のみ。git には載せない）
/session-report-*.html
outputs/clients/minpaku-cleaning/app/demo-output/

# responsive-snap / responsive-audit 生成物
/tmp/
scripts/.responsive-tools/node_modules/
