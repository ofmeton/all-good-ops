# ====================================================================
# x-account-system .env (Phase 0 Week 0 段階)
#
# 取り扱い:
# - このファイルは .gitignore 対象外 (テンプレートとしてコミット)
# - 実値は .env.local に書き、git に乗せない
# - 値が空のものは Phase 0 Week 0 で取得が必要 = HUMAN_TASKS.md 参照
# ====================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Anthropic ZDR (Zero Data Retention) 契約フラグ — Phase 1 で顧客素材投入する場合のみ true
ANTHROPIC_ZDR_ENABLED=false

# --- OpenAI (Visualizer) ---
OPENAI_API_KEY=
# gpt-image-2 を使う場合は v2、フォールバックは v1
OPENAI_IMAGE_MODEL=gpt-image-2

# --- X (Twitter) OAuth 2.0 PKCE ---
# X Developer Console で OAuth 2.0 App を作成 (Confidential Client = NO)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/oauth/x/callback
# 必須 scope (offline.access 必須、外すと refresh token 出ない)
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access
# 取得済 token (本番は Supabase 経由 + 暗号化保管、ローカル test は .env.local で OK)
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_TOKEN_EXPIRES_AT=

# --- twitterapi.io (海外バズ + 国内 AI 公式追跡) ---
TWITTERAPI_IO_KEY=

# --- Meta / Instagram Graph API ---
META_APP_ID=
META_APP_SECRET=
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# --- Supabase ---
# Phase 0 Week 0 で project 作成必要 (Free tier の 2 project 制限に注意)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# ofmeton 個人 LINE user ID (承認通知の宛先)
LINE_USER_ID_OFMETON=

# --- Cloudflare Workers ---
# Workers Paid プラン契約後に取得
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- 月予算ガード ---
# v10.2 §3.3.4 brownout 条件
BUDGET_MONTHLY_LIMIT_JPY=10000
BUDGET_BROWNOUT_THRESHOLD_JPY=11500

# --- 環境 ---
NODE_ENV=development
LOG_LEVEL=info
